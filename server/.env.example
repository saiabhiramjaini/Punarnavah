# Server environment variables — copy to .env and fill in real values

# Database (Neon / Postgres connection string)
DATABASE_URL=

# Server config
PORT=8080
NODE_ENV=development

# Frontend origin (used for CORS + cookie settings)
CLIENT_URL=http://localhost:5173

# Auth
JWT_SECRET=

# Email (Gmail address + Gmail App Password, NOT your account password)
SENDER_EMAIL=
SENDER_PASS=

# Cashfree payment gateway credentials
CLIENT_ID=
CLIENT_SECRET=
