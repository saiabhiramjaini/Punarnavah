# Client environment variables — copy to .env and fill in real values
# NOTE: every VITE_* var is bundled into the browser and is publicly visible.
# Never put API secrets here — only the unsigned upload preset + cloud name.

# Backend API base URL
VITE_BACKEND_URL=http://localhost:8080

# Cloudinary (unsigned upload only)
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
VITE_CLOUDINARY_URL=https://api.cloudinary.com/v1_1/<cloud_name>/image/upload
